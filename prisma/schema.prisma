// Prisma schema for Placement ERP System
// Generated from placement_backup.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH & RBAC
// ─────────────────────────────────────────────

model Role {
  role_id          Int              @id @default(autoincrement())
  role_name        String           @db.VarChar(50)
  role_description String?          @db.Text
  created_at       DateTime?        @default(now())
  users            User[]
  role_permissions RolePermission[]

  @@index([role_name], map: "idx_roles_role_name")
  @@index([created_at(sort: Desc)], map: "idx_roles_created_at")
  @@index([role_name, created_at(sort: Desc)], map: "idx_roles_name_created")
  @@map("roles")
}

model Permission {
  permission_id   Int              @id @default(autoincrement())
  permission_name String           @db.VarChar(100)
  module          String?          @db.VarChar(50)
  description     String?          @db.Text
  role_permissions RolePermission[]

  @@index([permission_name], map: "idx_permissions_permission_name")
  @@index([module], map: "idx_permissions_module")
  @@map("permissions")
}

model RolePermission {
  role_id       Int
  permission_id Int
  role          Role       @relation(fields: [role_id], references: [role_id], onDelete: Cascade)
  permission    Permission @relation(fields: [permission_id], references: [permission_id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([role_id], map: "idx_role_permissions_role_id")
  @@index([permission_id], map: "idx_role_permissions_permission_id")
  @@index([role_id, permission_id], map: "idx_role_permissions_role_perm")
  @@map("role_permissions")
}

model User {
  user_id              Int            @id @default(autoincrement())
  username             String         @unique @db.VarChar(100)
  email                String         @unique @db.VarChar(255)
  password_hash        String         @db.Text
  role_id              Int?
  is_active            Boolean?       @default(true)
  is_locked            Boolean?       @default(false)
  failed_attempts      Int?           @default(0)
  lock_until           DateTime?
  must_change_password Boolean?       @default(false)
  created_at           DateTime?      @default(now())
  updated_at           DateTime?      @default(now())

  role          Role?          @relation(fields: [role_id], references: [role_id])
  student_users StudentUser[]
  user_session  UserSession?

  @@index([role_id], map: "idx_users_role_id")
  @@index([created_at(sort: Desc)], map: "idx_users_created_at")
  @@map("users")
}

model UserSession {
  session_id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            Int       @unique
  refresh_token_hash String    @db.Text
  ip_address         String?   @db.Inet
  user_agent         String?   @db.Text
  created_at         DateTime? @default(now())
  last_activity      DateTime? @default(now())
  expires_at         DateTime

  user               User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("user_sessions")
}

// ─────────────────────────────────────────────
// STUDENTS
// ─────────────────────────────────────────────

model Student {
  student_id           Int                    @id @default(autoincrement())
  first_name           String?                @db.VarChar(100)
  middle_name          String?                @db.VarChar(100)
  last_name            String?                @db.VarChar(100)
  full_name            String?                @db.VarChar(300)
  gender               String?                @db.VarChar(20)
  dob                  DateTime?              @db.Date
  email                String?                @db.VarChar(150)
  alt_email            String?                @db.VarChar(150)
  college_email        String?                @db.VarChar(150)
  mobile               String?                @db.VarChar(20)
  emergency_contact    String?                @db.VarChar(20)
  nationality          String?                @db.VarChar(50)
  placement_fee_status String?                @db.VarChar(50)
  student_photo_path   String?                @db.Text
  created_at           DateTime?              @default(now())
  academics            StudentAcademics?
  addresses            StudentAddress[]
  certifications       StudentCertification[]
  documents            StudentDocument[]
  family               StudentFamily?
  internships          StudentInternship[]
  languages            StudentLanguage[]
  offers               StudentOffer[]
  projects             StudentProject[]
  applications         Application[]
  placement_summary    PlacementSummary[]
  student_users        StudentUser[]

  @@map("students")
}

model StudentUser {
  student_id Int     @id
  user_id    Int?
  user       User?   @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  student    Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@index([student_id], map: "idx_student_users_student_id")
  @@map("student_users")
}

model StudentAcademics {
  student_id      Int      @id
  tenth_percent   Decimal? @db.Decimal(5, 2)
  tenth_year      Int?
  tenth_board     String?  @db.VarChar(100)
  tenth_school    String?  @db.VarChar(200)
  twelfth_percent Decimal? @db.Decimal(5, 2)
  twelfth_year    Int?
  twelfth_board   String?  @db.VarChar(100)
  twelfth_college String?  @db.VarChar(200)
  diploma_percent Decimal? @db.Decimal(5, 2)
  diploma_year    Int?
  diploma_college String?  @db.VarChar(200)
  ug_cgpa         Decimal? @db.Decimal(4, 2)
  ug_year_of_passing Int?
  pg_cgpa         Decimal? @db.Decimal(4, 2)
  history_of_backs Int?
  updated_arrears Int?
  gap_years       Int?
  cet_rank        Int?
  comedk_rank     Int?
  category        String?  @db.VarChar(50)
  student         Student  @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@map("student_academics")
}

model StudentAddress {
  address_id        Int     @id @default(autoincrement())
  student_id        Int
  permanent_address String? @db.Text
  permanent_city    String? @db.VarChar(100)
  permanent_state   String? @db.VarChar(100)
  permanent_pin     String? @db.VarChar(20)
  permanent_contact String? @db.VarChar(20)
  current_address   String? @db.Text
  current_city      String? @db.VarChar(100)
  current_state     String? @db.VarChar(100)
  current_pin       String? @db.VarChar(20)
  student           Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@map("student_addresses")
}

model StudentCertification {
  cert_id          Int     @id @default(autoincrement())
  student_id       Int
  skill_name       String? @db.VarChar(200)
  duration         String? @db.VarChar(50)
  vendor           String? @db.VarChar(200)
  certificate_file String? @db.Text
  student          Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@map("student_certifications")
}

model StudentDocument {
  doc_id        Int       @id @default(autoincrement())
  student_id    Int
  document_type String?   @db.VarChar(80)
  file_path     String?   @db.Text
  uploaded_at   DateTime? @default(now())
  student       Student   @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@map("student_documents")
}

model StudentFamily {
  student_id        Int     @id
  father_name       String? @db.VarChar(150)
  father_occupation String? @db.VarChar(150)
  father_phone      String? @db.VarChar(20)
  mother_name       String? @db.VarChar(150)
  mother_occupation String? @db.VarChar(150)
  mother_phone      String? @db.VarChar(20)
  blood_group       String? @db.VarChar(10)
  student           Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@map("student_family")
}

model StudentInternship {
  internship_id   Int       @id @default(autoincrement())
  student_id      Int
  organization    String?   @db.VarChar(200)
  skills_acquired String?   @db.Text
  duration        String?   @db.VarChar(50)
  start_date      DateTime? @db.Date
  end_date        DateTime? @db.Date
  description     String?   @db.Text
  stipend         Decimal?  @db.Decimal(12, 2)
  student         Student   @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@map("student_internships")
}

model StudentLanguage {
  lang_id    Int     @id @default(autoincrement())
  student_id Int
  language   String? @db.VarChar(100)
  level      String? @db.VarChar(50)
  student    Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@map("student_languages")
}

model StudentOffer {
  offer_id         Int       @id @default(autoincrement())
  student_id       Int
  job_id           Int
  offered_at       DateTime? @default(now())
  is_primary_offer Boolean?  @default(false)
  is_pbc           Boolean?  @default(false)
  is_internship    Boolean?  @default(false)
  offer_ctc        Decimal?  @db.Decimal(9, 2)
  offer_stipend    Decimal?  @db.Decimal(12, 2)
  remarks          String?   @db.Text
  student          Student   @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  job              Job       @relation(fields: [job_id], references: [job_id], onDelete: Cascade)

  @@map("student_offers")
}

model StudentProject {
  project_id  Int     @id @default(autoincrement())
  student_id  Int
  title       String? @db.VarChar(200)
  description String? @db.Text
  tools_used  String? @db.Text
  student     Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)

  @@map("student_projects")
}

// ─────────────────────────────────────────────
// COMPANIES & JOBS
// ─────────────────────────────────────────────

model Company {
  company_id     Int       @id @default(autoincrement())
  company_name   String    @db.VarChar(200)
  company_type   String?   @db.VarChar(50)
  website        String?   @db.VarChar(255)
  contact_person String?   @db.VarChar(150)
  contact_email  String?   @db.VarChar(150)
  contact_phone  String?   @db.VarChar(30)
  created_at     DateTime? @default(now())
  company_logo   String?   @db.VarChar(500)
  jobs           Job[]

  @@map("companies")
}

model Job {
  job_id               Int                  @id @default(autoincrement())
  company_id           Int
  job_title            String               @db.VarChar(200)
  job_description      String?              @db.Text
  job_type             String?              @db.VarChar(50)
  ctc_lpa              Decimal?             @db.Decimal(9, 2)
  stipend_per_month    Decimal?             @db.Decimal(12, 2)
  location             String?              @db.VarChar(200)
  interview_mode       String?              @db.VarChar(50)
  application_deadline DateTime?            @db.Date
  drive_date           DateTime?            @db.Date
  created_at           DateTime?            @default(now())
  company              Company              @relation(fields: [company_id], references: [company_id], onDelete: Cascade)
  requirements         JobRequirement[]
  applications         Application[]
  offers               StudentOffer[]
  placement_drive_stats PlacementDriveStats[]
  placement_summaries  PlacementSummary[]

  @@map("jobs")
}

model JobRequirement {
  job_requirement_id Int      @id @default(autoincrement())
  job_id             Int
  tenth_percent      Decimal? @db.Decimal(5, 2)
  twelfth_percent    Decimal? @db.Decimal(5, 2)
  ug_cgpa            Decimal? @db.Decimal(4, 2)
  pg_cgpa            Decimal? @db.Decimal(4, 2)
  min_experience_yrs Decimal? @db.Decimal(4, 2)
  allowed_branches   String[] @db.Text
  skills_required    String?  @db.Text
  additional_notes   String?  @db.Text
  job                Job      @relation(fields: [job_id], references: [job_id], onDelete: Cascade)

  @@map("job_requirements")
}

// ─────────────────────────────────────────────
// APPLICATIONS & PLACEMENTS
// ─────────────────────────────────────────────

model Application {
  application_id Int       @id @default(autoincrement())
  student_id     Int
  job_id         Int
  applied_at     DateTime? @default(now())
  status         String?   @db.VarChar(50)
  offer_type     String?   @db.VarChar(50)
  offer_ctc      Decimal?  @db.Decimal(9, 2)
  offer_stipend  Decimal?  @db.Decimal(12, 2)
  placement_date DateTime? @db.Date
  remarks        String?   @db.Text
  student        Student   @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  job            Job       @relation(fields: [job_id], references: [job_id], onDelete: Cascade)

  @@map("applications")
}

model PlacementDriveStats {
  id                Int       @id @default(autoincrement())
  job_id            Int
  total_offers      Int?
  fte_offers        Int?
  pbc_offers        Int?
  internship_offers Int?
  updated_at        DateTime? @default(now())
  job               Job       @relation(fields: [job_id], references: [job_id], onDelete: Cascade)

  @@map("placement_drive_stats")
}

model PlacementSummary {
  summary_id  Int       @id @default(autoincrement())
  student_id  Int
  total_offers Int?
  highest_ctc Decimal?  @db.Decimal(9, 2)
  final_job_id Int?
  updated_at  DateTime? @default(now())
  student     Student   @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  final_job   Job?      @relation(fields: [final_job_id], references: [job_id], onDelete: SetNull)

  @@map("placement_summary")
}
